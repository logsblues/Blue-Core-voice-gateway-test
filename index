    // Check deduplication
    const dedupCheck = ToolDeduplicator.shouldExecute(session, toolName, args);
    if (!dedupCheck.shouldExecute) {
      const result = dedupCheck.previousResult || { success: false, error: "Duplicate call detected" };
      this._sendToolResult(session, callId, result, toolName);
      return result;
    }

    let result;

    try {
      if (toolName === "end_call") {
        // ✅ v6.3.0 POINT C: If AI calls end_call during voicemail mode, force hangup
        if (session.isVoicemailMode) {
          // ✅ CHANGE 4: Delay hangup to allow TTS audio playback to finish.
          // The AI calls end_call as soon as it finishes generating text, but the
          // audio (TTS) is still streaming to Twilio. Without this delay, the WS
          // closes mid-playback and the caller hears a truncated voicemail message.
          const scriptLen = session.voicemailConfig?.voicemailScript?.length || 0; // ✅ BUG FIX v7.2.7: was .voicemail_script (wrong key)
          // Estimate playback time: ~12 chars/sec TTS + 3s buffer, minimum 15s
          const estimatedPlaybackMs = Math.max(15000, Math.ceil(scriptLen / 12) * 1000 + 3000);
          logger.info("[CHANGE 4] AI called end_call in voicemail mode — delaying hangup for audio playback", {
            callSid: session.callSid,
            scriptLen,
            delayMs: estimatedPlaybackMs
          });
          setTimeout(() => {
            if (!session.voicemailHungUp) VoicemailDetector.forceHangup(session);
          }, estimatedPlaybackMs);
          result = { success: true, action: "voicemail_hangup_delayed", delayMs: estimatedPlaybackMs };
        } else {
          result = await this._executeEndCall(session, args);
        }
      } else if (toolName === "transfer_to_human") {
        result = await this._executeTransfer(session, args);
      } else if (toolName === "lookup_contact") {
        result = await this._executeLookup(session, args);
      } else {
        const phone = this.getCustomerPhone(session, args);
        result = await CRMToolsClient.executeTool(toolName, { ...args, phone }, {
          companyId: session.companyId, agentId: session.agentId,
          callSid: session.callSid, customerPhone: phone, direction: session.direction
        });
      }
    } catch (error) {
      result = { success: false, error: error.message };
    }

    const duration = Date.now() - startTime;
    ToolDeduplicator.recordExecution(session, toolName, args, result);

    // NEW v7: Record to persistent tool call log
    ToolCallLogger.record(session, toolName, args, result, duration);

    logger.info("Tool execution completed", { callSid: session.callSid, toolName, durationMs: duration, success: result?.success !== false });

    this._sendToolResult(session, callId, result, toolName);
    return result;
  }

  static _sendToolResult(session, callId, result, toolName) {
    // FIX #1: Always send tool result for transfer_to_human even if callEnding
    const isTransfer = toolName === "transfer_to_human";
    if (session.openaiWs?.readyState === WebSocket.OPEN && (!session.callEnding || isTransfer)) {
      session.openaiWs.send(JSON.stringify({
        type: "conversation.item.create",
        item: {
          type: "function_call_output",
          call_id: callId,
          output: JSON.stringify(result)
        }
      }));

      // Only request a response if NOT ending the call
      if (!session.callEnding) {
        // ── v7.3.6 FIX: skip AI response if screening is active ──
        if (session.screeningActive && toolName === "transfer_to_human") {
          logger.info("[TOOL_RESULT] Skipping response.create — screening active", {
            callSid: session.callSid
          });
        } else {
          ResponseLockManager.sendResponseCreateSafe(
            session,
            { type: "response.create", response: { modalities: ["text", "audio"] } },
            "tool_result_" + toolName
          );
        }
        // ── end fix ──
      }
    }
  }

  static async _executeEndCall(session, args) {
    logger.info("End call processing", { callSid: session.callSid });
    const goodbye = args.goodbye_message || args.goodbyeMessage || "Goodbye, have a great day!";

    if (session.openaiWs?.readyState === WebSocket.OPEN) {
      session.openaiWs.send(JSON.stringify({
        type: "conversation.item.create",
        item: {
          type: "message", role: "user",  // ✅ FIX BUG-1: "system" is invalid in conversation.item.create
          content: [{ type: "input_text", text: `[SYSTEM] [END CALL - MANDATORY GOODBYE] Say exactly: "${goodbye}" — Do NOT add anything else.` }]
        }
      }));
      ResponseLockManager.sendResponseCreateSafe(
        session,
        { type: "response.create", response: { modalities: ["text", "audio"] } },
        "end_call"
      );
    }

    session.callEnding = true;
    setTimeout(() => {
      if (session.openaiWs?.readyState === WebSocket.OPEN) session.openaiWs.close(1000, "end_call");
      setTimeout(() => {
        if (session.twilioWs?.readyState === WebSocket.OPEN) session.twilioWs.close(1000, "end_call");
      }, 500);
    }, 3500);

    return { success: true, message: "Call ended" };
  }

  static async _resolveTwilioTokenForOwner(session) {
    const ownerSid = session.twilioOwnerSid;
    if (!ownerSid) {
      logger.warn("No twilioOwnerSid in session, falling back to env", { callSid: session.callSid });
      return process.env.TWILIO_AUTH_TOKEN || null;
    }

    // 1) If ownerSid matches master env → use master token
    if (ownerSid === process.env.TWILIO_ACCOUNT_SID) {
      logger.info("Owner matches master env SID", { callSid: session.callSid });
      return process.env.TWILIO_AUTH_TOKEN;
    }

    // 2) Look up token from bc_communications_settings
    if (session.companyId) {
      try {
        const bcRes = await SupabaseClient.request(
          "bc_communications_settings?company_id=eq." + session.companyId +
          "&select=twilio_subaccount_sid,twilio_subaccount_auth_token,twilio_account_sid,twilio_auth_token"
        );
        const bc = bcRes.ok && bcRes.data?.[0];

        if (bc?.twilio_subaccount_sid === ownerSid && bc?.twilio_subaccount_auth_token) {
          logger.info("Resolved token from bc_communications_settings (subaccount)", { callSid: session.callSid });
          return bc.twilio_subaccount_auth_token;
        }
        if (bc?.twilio_account_sid === ownerSid && bc?.twilio_auth_token) {
          logger.info("Resolved token from bc_communications_settings (account)", { callSid: session.callSid });
          return bc.twilio_auth_token;
        }
      } catch (e) {
        logger.warn("Failed to query bc_communications_settings for token", { error: e.message });
      }

      // 3) Fallback to communications_settings (production table)
      //    ⚠ CRITICAL: Column names DIFFER from bc_ table!
      //    - subaccount_sid        (NOT twilio_subaccount_sid)
      //    - subaccount_auth_token (NOT twilio_subaccount_auth_token)
      //    - sms_account_sid       (NOT twilio_account_sid)
      //    - NO twilio_auth_token column exists
      try {
        const prodRes = await SupabaseClient.request(
          "communications_settings?company_id=eq." + session.companyId +
          "&select=subaccount_sid,subaccount_auth_token,sms_account_sid"
        );
        const prod = prodRes.ok && prodRes.data?.[0];

        if (prod?.subaccount_sid === ownerSid && prod?.subaccount_auth_token) {
          logger.info("Resolved token from communications_settings (subaccount)", { callSid: session.callSid });
          return prod.subaccount_auth_token;
        }
        // communications_settings does not store a separate master auth token
        // If subaccount_sid doesn't match, fall through to env var fallback
      } catch (e) {
        logger.warn("Failed to query communications_settings for token", { error: e.message });
      }
    }

    // 4) Last resort: try master token anyway (master can operate on subaccount calls)
    logger.warn("Could not resolve specific token for owner, trying master as last resort", {
      callSid: session.callSid,
      ownerSid: ownerSid.substring(0, 12) + "..."
    });
    return process.env.TWILIO_AUTH_TOKEN || null;
  }

  static async _executeTransfer(session, args) {
    // FIX #8: Prevent double execution
    if (session.transferInProgress) {
      logger.warn("Transfer already in progress, ignoring duplicate call", { callSid: session.callSid });
      return { success: false, error: "Transfer already in progress" };
    }
    session.transferInProgress = true;

    // ── v7.3.6 FIX: suppress AI audio IMMEDIATELY before screening ──
    session.suppressModelAudio = true;
    // DO NOT set screeningActive here — initiateScreening() sets it internally after its own guard check
    try {
      session.openaiWs?.send(JSON.stringify({ type: "response.cancel" }));
      logger.info("[TRANSFER] Cancelled active AI response before screening", { callSid: session.callSid });
    } catch (_) {}
    // ── end fix ──

    try {
      // ==================== NEW: Use Call Screening Engine ====================
      const result = await CallScreeningEngine.initiateScreening(session, {
        customer_name: session.preloadedContact?.safeName || args?.customer_name || "",
        customer_company: args?.customer_company || "",
        reason_summary: args?.reason || args?.reason_summary || "",
      });

      if (!result.success) {
        // Fallback to legacy transfer if screening fails
        logger.warn("[TRANSFER] Screening failed, falling back to legacy", {
          callSid: session.callSid,
          error: result.error,
        });
        session.transferInProgress = false;
        return await this._executeLegacyTransfer(session, args);
      }

      return {
        success: true,
        action: result.action,
        voicecore_call_id: result.voicecore_call_id,
        message: "Call screening initiated. The system is checking agent availability.",
      };

    } catch (error) {
      session.transferInProgress = false;
      logger.error("[TRANSFER] Screening exception, falling back", { error: error.message });
      return await this._executeLegacyTransfer(session, args);
    }
  }

  static async _executeLegacyTransfer(session, args) {
    // FIX #8: Prevent double execution
    if (session.transferInProgress) {
      logger.warn("Transfer already in progress, ignoring duplicate call", { callSid: session.callSid });
      return { success: false, error: "Transfer already in progress" };
    }
    session.transferInProgress = true;

    try {
      // 1. Resolve target via agent-router edge function (availability-aware)
      const target = await resolveTransferTarget(session, args);
      if (!target) {
        session.transferInProgress = false;
        logger.warn("Transfer: no available agent found via agent-router", { callSid: session.callSid });
        return { success: false, error: "No available agent found" };
      }

      const { dialTarget, agentName, agentId, lockId } = target;
      // Store lockId so releaseAgentOnCallEnd can release it
      session.transferLockId = lockId;
      session.transferAgentId = agentId;

      // 2. Resolve Twilio credentials using OWNER SID (not env vars)
      const twilioSid = session.twilioOwnerSid || process.env.TWILIO_ACCOUNT_SID;
      let twilioToken = session.twilioOwnerToken;
      if (!twilioToken) {
        twilioToken = await this._resolveTwilioTokenForOwner(session);
      }
      if (!twilioSid || !twilioToken) {
        session.transferInProgress = false;
        return { success: false, error: "Twilio credentials not available for transfer (owner: " + (twilioSid?.substring(0, 12) || "none") + ")" };
      }

      // 3. Tell the AI to announce the transfer
      //    FIX #9: Use role:"user" (OpenAI Realtime only accepts "user"/"assistant")
      if (session.openaiWs?.readyState === WebSocket.OPEN) {
        session.openaiWs.send(JSON.stringify({
          type: "conversation.item.create",
          item: {
            type: "message",
            role: "user",
            content: [{ type: "input_text", text: `[TRANSFER] Say exactly: "Transferring your call to ${agentName}, please hold." - Do NOT say anything else after this.` }]
          }
        }));
        ResponseLockManager.sendResponseCreateSafe(
          session,
          { type: "response.create", response: { modalities: ["text", "audio"] } },
          "transfer_announce"
        );
      }

      // FIX #1: Do NOT set callEnding here — it blocks _sendToolResult.
      // It will be set inside the setTimeout AFTER the tool result has been sent.

      // 4. Execute Twilio redirect after delay for AI announcement
      session.transferTimeout = setTimeout(async () => {
        // FIX #3: Verify session is still valid before executing
        if (!session.callSid || session.sessionDestroyed) {
          logger.warn("Session already destroyed before transfer redirect", { callSid: session.callSid || "unknown" });
          return;
        }

        // NOW set callEnding (FIX #1: after tool result was already sent)
        session.callEnding = true;

        try {
          const twiml = `<Response><Say voice="Polly.Lupe-Neural" language="es-US">Transfiriendo su llamada a ${agentName}. Por favor espere.</Say><Dial timeout="30"><Number>${dialTarget}</Number></Dial><Say voice="Polly.Lupe-Neural" language="es-US">No pudimos completar la transferencia. Intente mas tarde.</Say><Hangup/></Response>`;

          const twilioUrl = `https://api.twilio.com/2010-04-01/Accounts/${twilioSid}/Calls/${session.callSid}.json`;
          const authHeader = "Basic " + Buffer.from(`${twilioSid}:${twilioToken}`).toString("base64");

          logger.info("Executing Twilio transfer redirect", {
            callSid: session.callSid,
            dialTarget,
            agentName,
            ownerSid: twilioSid.substring(0, 12) + "...",
            lockId
          });

          const twilioRes = await fetch(twilioUrl, {
            method: "POST",
            headers: {
              "Authorization": authHeader,
              "Content-Type": "application/x-www-form-urlencoded"
            },
            body: new URLSearchParams({ Twiml: twiml }).toString()
          });

          if (!twilioRes.ok) {
            const errText = await twilioRes.text();
            logger.error("Twilio transfer redirect FAILED", {
              callSid: session.callSid,
              status: twilioRes.status,
              error: errText,
              usedSid: twilioSid.substring(0, 12) + "..."
            });
            // Release lock on failure so agent becomes available again
            releaseAgentOnCallEnd(session).catch(() => {});
          } else {
            logger.info("Twilio transfer redirect SUCCESS", { callSid: session.callSid, dialTarget, agentName });
          }

          // 5. Update call record (non-critical)
          try {
            await SupabaseClient.request("calls?call_sid=eq." + session.callSid, "PATCH", {
              transferred_to_agent_id: agentId,
              call_state: "transferred"
            });
          } catch (e) { /* non-critical */ }

          // 6. Close WebSockets after redirect takes effect
          setTimeout(() => {
            if (session.openaiWs?.readyState === WebSocket.OPEN) session.openaiWs.close(1000, "transfer");
            if (session.twilioWs?.readyState === WebSocket.OPEN) session.twilioWs.close(1000, "transfer");
          }, 2000);

        } catch (transferErr) {
          logger.error("Transfer execution error", { callSid: session.callSid, error: transferErr.message });
          releaseAgentOnCallEnd(session).catch(() => {});
        }
      }, 2500); // Wait 2.5s for AI announcement before Twilio redirect

      return { success: true, transfer_to: dialTarget, agent_name: agentName, action: "transfer" };

    } catch (e) {
      session.transferInProgress = false;
      return { success: false, error: e.message };
    }
  }

  static async _executeLookup(session, args) {
    if (session.preloadedContact) return { found: true, contact: session.preloadedContact, source: "preloaded" };
    const phone = this.getCustomerPhone(session, args);
    try {
      const res = await SupabaseClient.request("crm_contacts?phone=eq." + encodeURIComponent(phone) + "&select=*");
      if (res.ok && res.data?.[0]) {
        const c = res.data[0];
        session.preloadedContact = {
          id: c.id, name: c.name || c.full_name,
          email: c.email, phone: c.phone,
          language: c.language || DEFAULT_LANGUAGE
        };
        return { found: true, contact: session.preloadedContact };
      }
      return { found: false, message: "Contact not found" };
    } catch (e) {
      return { found: false, error: e.message };
    }
  }

  /**
   * Build tool definitions for OpenAI session.update
   * ENHANCED v7: Uses dynamic tools from bc_agent_tools if loaded, otherwise hardcoded defaults
   */
  static buildToolDefinitions(session, config) {
    // v7.2.0: If dynamicTools is an empty array, return NO tools (interpreter/no-tools mode)
    if (Array.isArray(session.dynamicTools) && session.dynamicTools.length === 0) {
      logger.info("Using empty tool set (interpreter/no-tools mode)", { callSid: session.callSid });
      return [];
    }

    // NEW v7: If dynamic tools were loaded from DB, convert them to OpenAI format
    if (session.dynamicTools?.length > 0) {
      const tools = session.dynamicTools
        .filter(t => t.schema)
        .map(t => {
          // If schema is already in OpenAI format, use directly
          if (t.schema.type === "function" && t.schema.function) {
            return t.schema;
          }
          // Wrap in OpenAI format
          return {
            type: "function",
            name: t.name,
            description: t.schema.description || t.name,
            parameters: t.schema.parameters || t.schema
          };
        });

      // Always ensure end_call and transfer_to_human are available
      const hasEndCall = tools.some(t => (t.name || t.function?.name) === "end_call");
      const hasTransfer = tools.some(t => (t.name || t.function?.name) === "transfer_to_human");

      if (!hasEndCall) {
        tools.push({ type: "function", name: "end_call", description: "End the call politely.", parameters: { type: "object", properties: { reason: { type: "string" }, outcome: { type: "string" }, goodbye_message: { type: "string" } } } });
      }
      if (!hasTransfer) {
        tools.push({ type: "function", name: "transfer_to_human", description: "Transfer call to a human agent.", parameters: { type: "object", properties: { agent_name: { type: "string" }, reason: { type: "string" } }, required: ["reason"] } });
      }

      logger.info("Using dynamic tools from DB", { count: tools.length });
      return tools;
    }

    // Fallback: hardcoded tool definitions (original v6.2.0 behavior)
    const tools = [];
    const hasContact = session.preloadedContact?.name;
    const isDemoCall = session.isDemoCall === true;

    if (!hasContact) {
      tools.push({ type: "function", name: "lookup_contact", description: "Look up contact by phone number.", parameters: { type: "object", properties: { phone: { type: "string", description: "Phone number to search" }, email: { type: "string", description: "Email to search" } } } });
    }

    tools.push({ type: "function", name: "create_or_merge_contact", description: "Create new contact or update existing.", parameters: { type: "object", properties: { phone: { type: "string" }, name: { type: "string" }, email: { type: "string" } }, required: ["phone", "name"] } });
    tools.push({ type: "function", name: "create_lead", description: "Create a lead for opportunity tracking.", parameters: { type: "object", properties: { contact_id: { type: "string" }, phone: { type: "string" }, title: { type: "string" }, notes: { type: "string" }, temperature: { type: "string", enum: ["hot", "warm", "cold"] } }, required: ["title"] } });

    if (!isDemoCall) {
      tools.push({ type: "function", name: "schedule_appointment", description: "Schedule an appointment.", parameters: { type: "object", properties: { phone: { type: "string" }, name: { type: "string" }, start_at: { type: "string", description: "ISO datetime" }, title: { type: "string" }, notes: { type: "string" } }, required: ["start_at"] } });
    }

    tools.push({ type: "function", name: "check_appointments", description: "Check upcoming appointments.", parameters: { type: "object", properties: { phone: { type: "string" } }, required: ["phone"] } });
    tools.push({ type: "function", name: "take_note", description: "Save a note about the call.", parameters: { type: "object", properties: { note: { type: "string" } }, required: ["note"] } });
    tools.push({ type: "function", name: "send_message", description: "Send an SMS to the customer.", parameters: { type: "object", properties: { phone: { type: "string" }, message: { type: "string" } }, required: ["message"] } });
    tools.push({ type: "function", name: "send_email", description: "Send an email.", parameters: { type: "object", properties: { email: { type: "string" }, subject: { type: "string" }, body: { type: "string" } }, required: ["subject", "body"] } });
    tools.push({ type: "function", name: "transfer_to_human", description: "Transfer call to a human agent.", parameters: { type: "object", properties: { agent_name: { type: "string" }, reason: { type: "string" } }, required: ["reason"] } });
    tools.push({ type: "function", name: "end_call", description: "End the call politely.", parameters: { type: "object", properties: { reason: { type: "string" }, outcome: { type: "string" }, goodbye_message: { type: "string" } } } });

    return tools;
  }
}

