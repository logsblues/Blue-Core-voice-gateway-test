      isVoicemailMode: false,
      voicemailHungUp: false,
      voicemailTimeout: null,
      voicemailConfig: null,  // ✅ FIX 3 v7.2.7: Will be populated from prewarm params
      aiTurnCount: 0,       // ✅ v6.3.0 POINT D: monologue detection
      userTurnCount: 0,     // ✅ v6.3.0 POINT D: monologue detection
            firstAudioSent: false,
            pendingSessionUpdate: false,
            responseLock: { isLocked: false, lockedBy: null, lockedAt: null },
            metrics: { t_session_created: Date.now() },
            createdAt: Date.now()
          };

          if (data.contact_name) {
            session.preloadedContact = {
