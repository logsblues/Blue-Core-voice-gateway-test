/**
 * Resolve the best available human agent via the agent-router edge function.
 * Returns { dialTarget, agentName, agentId, lockId } or null if unavailable.
 */
async function resolveTransferTarget(session, args) {
  const companyId = session.companyId;
  const callSid = session.callSid || session.twilioCallSid;
  const agentName = args?.agent_name || args?.agentName || session.transferAgentName || null;

  if (!companyId || !callSid) {
    logger.warn("[TRANSFER] Missing companyId/callSid", { companyId, callSid });
    return null;
  }

  logger.info("[TRANSFER] Calling agent-router", { companyId, callSid, agentName });

  try {
    const resp = await fetch(`${SUPABASE_URL}/functions/v1/agent-router`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": `Bearer ${SUPABASE_SERVICE_KEY}`,
      },
      body: JSON.stringify({
        action: "claim",
        company_id: companyId,
        call_sid: callSid,
        preferred_agent_name: agentName,
      }),
    });

    const result = await resp.json().catch(() => ({}));
    logger.info("[TRANSFER] agent-router result", {
      ok: resp.ok,
      success: result?.success,
      agent: result?.agent_name,
      dial: result?.dial_target,
      reason: result?.reason,
    });

    if (!resp.ok || !result?.success || !result?.dial_target) return null;

    return {
      dialTarget: result.dial_target,
      agentName: result.agent_name,
      agentId: result.agent_id,
      lockId: result.lock_id,
    };
  } catch (e) {
    logger.error("[TRANSFER] agent-router fetch error", { callSid, error: e.message });
    return null;
  }
}

/**
 * Release the agent lock when the call ends (fire-and-forget).
 */
async function releaseAgentOnCallEnd(session) {
  const callSid = session.callSid || session.twilioCallSid;
  const companyId = session.companyId;
  if (!callSid || !companyId) return;
  try {
    await fetch(`${SUPABASE_URL}/functions/v1/agent-router`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": `Bearer ${SUPABASE_SERVICE_KEY}`,
      },
      body: JSON.stringify({ action: "release", company_id: companyId, call_sid: callSid }),
    });
    logger.info("[CLEANUP] Released agent lock", { callSid });
  } catch (e) {
    logger.warn("[CLEANUP] Release failed", { callSid, error: String(e) });
  }
}

class ToolExecutor {
  static getCustomerPhone(session, args) {
    const phone = args.phone || session.customerPhone ||
      (session.direction === "outbound" ? session.toNumber : session.fromNumber) ||
      session.fromNumber || session.toNumber;
    if (phone && !args.phone) args.phone = phone;
    return Parser.normalizePhone(phone);
  }

  static async execute(session, toolName, callId, args) {
    // ✅ FIX BUG-2: Allow transfer_to_human even if callEnding is active (race condition guard)
    if (session.callEnding && toolName !== "transfer_to_human") {
      logger.debug("Tool blocked (call ending)", { toolName, callSid: session.callSid });
      return;
