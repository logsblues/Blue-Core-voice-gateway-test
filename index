    for (const [, session] of sessions.entries()) {
      if (session.callSid === callSid) return session;
    }
    return null;
  }

  static deleteSession(sessionId) {
    const session = sessions.get(sessionId);
    if (session) {
      // ✅ FIX RES-2 + RES-3: Cancel ALL pending timers to prevent post-hangup execution
      if (session.autoHangupTimer) clearTimeout(session.autoHangupTimer);
      if (session.autoHangupTimeout) clearTimeout(session.autoHangupTimeout);
      if (session.transferTimeout) clearTimeout(session.transferTimeout);
      if (session.silenceTimeout) clearTimeout(session.silenceTimeout);
      if (session.greetingTimer) clearTimeout(session.greetingTimer);
      if (session.ringbackInterval) clearInterval(session.ringbackInterval);
      if (session.voicemailSafetyTimer) clearTimeout(session.voicemailSafetyTimer); // ✅ v6.4.0
      if (session.screeningHoldTimer) clearInterval(session.screeningHoldTimer);
      if (session.screeningPollTimer) clearInterval(session.screeningPollTimer);
      if (session.screeningTimeoutTimer) clearTimeout(session.screeningTimeoutTimer);
      session.sessionDestroyed = true;
      // ── v7.3.6 FIX: reset screening flags ──
      session.suppressModelAudio = false;
      session.screeningActive = false;
      // ── end fix ──
      // v7.1.0: Clean up interpreter partner references
      if (session.interpreterPartner) {
        session.interpreterPartner.interpreterPartner = null;
        logger.info("Interpreter partner unlinked", { callSid: session.callSid });
      }
      // Clean up interpreterPartners map
      if (session.prepId && interpreterPartners.has(session.prepId)) {
        interpreterPartners.delete(session.prepId);
      }

      if (session.companyId) {
        RateLimiter.decrementTenantCalls(session.companyId);
      }
      // NEW v7: Persist tool call logs before deleting
      ToolCallLogger.persist(session).catch(e =>
        logger.error("Tool log persist failed on delete", { error: e.message })
      );
      sessions.delete(sessionId);
      logger.info("Session deleted", {
        sessionId, callSid: session.callSid,
        durationMs: Date.now() - session.createdAt
      });
    }
  }

  static getActiveSessionCount() {
    return sessions.size;
  }

  static getPrewarmSessionCount() {
    return prewarmSessions.size;
  }
}

/**
 * ResponseLockManager - Prevent concurrent OpenAI responses
 */
class ResponseLockManager {
  static init(session) {
    session.responseLock = { isLocked: false, lockedBy: null, lockedAt: null };
  }

  static tryLock(session, reason) {
    if (!session.responseLock) this.init(session);
    if (session.responseLock.isLocked) return false;
    session.responseLock = { isLocked: true, lockedBy: reason, lockedAt: Date.now() };
    return true;
  }

  static unlock(session, reason) {
    if (session.responseLock?.isLocked) {
      const dur = Date.now() - (session.responseLock.lockedAt || Date.now());
      logger.debug("Response unlocked", { reason, durationMs: dur });
    }
    if (session.responseLock) {
      session.responseLock.isLocked = false;
      session.responseLock.lockedBy = null;
    }
  }

  static sendResponseCreateSafe(session, payload, reason) {
    if (session.callEnding) return false;
    if (!this.tryLock(session, "response.create:" + reason)) return false;
    if (session.openaiWs?.readyState === WebSocket.OPEN) {
      session.openaiWs.send(JSON.stringify(payload));
      return true;
    }
    return false;
  }
}

/**
 * Prewarm session management
 */
function createPrewarmSession(agentId, companyId, config) {
  const prepId = generatePrepId();
  const prewarmData = {
    prepId, agentId, companyId, config,
    openaiWs: null,
    sessionCreated: false,
    sessionReady: false,
    createdAt: Date.now(),
    _createdAt: Date.now(),          // ✅ v7.3.5: for max lifetime tracking
    _maxLifetimeMs: PREWARM_SESSION_MAX_AGE_MS, // ✅ v7.3.5: 55 min hard cap
    expiresAt: Date.now() + PREWARM_SESSION_TTL_MS
  };
  prewarmSessions.set(prepId, prewarmData);
  logger.info("Prewarm session created", { prepId, agentId, companyId });
  return prewarmData;
}

function getPrewarmSession(agentId, companyId) {
  const now = Date.now();
  for (const [prepId, prewarm] of prewarmSessions.entries()) {
    if (prewarm.agentId === agentId &&
      prewarm.companyId === companyId &&
      prewarm.sessionReady &&
      prewarm.expiresAt > now) {
      prewarmSessions.delete(prepId);
      logger.info("Prewarm session reused", { prepId, agentId, ageMs: now - prewarm.createdAt });
      return prewarm;
    }
  }
  return null;
}

function cleanupExpiredPrewarmSessions() {
  const now = Date.now();
  let cleaned = 0;
  let recycled = 0;
  for (const [prepId, prewarm] of prewarmSessions.entries()) {
    const age = now - (prewarm._createdAt || prewarm.createdAt || 0);
    const maxAge = prewarm._maxLifetimeMs || PREWARM_SESSION_MAX_AGE_MS;

    // ✅ v7.3.5: Hard cap — recycle sessions approaching OpenAI 60min WS limit
    if (age >= maxAge) {
      logger.info("[PREWARM] Recycling expired session (max lifetime)", {
        prepId,
        agentId: prewarm.agentId,
        ageMin: Math.round(age / 60000)
      });
      try { if (prewarm.openaiWs) prewarm.openaiWs.close(1000, "prewarm_max_lifetime"); } catch (e) {}
      prewarmSessions.delete(prepId);
      recycled++;
      // Recreate replacement session if agentId/companyId/config available
      if (prewarm.agentId && prewarm.companyId && prewarm.config) {
        try { createPrewarmSession(prewarm.agentId, prewarm.companyId, prewarm.config); } catch (e) {
          logger.warn("[PREWARM] Failed to recreate session after recycle", { prepId, err: String(e) });
        }
      }
      continue;
    }

    // Standard TTL expiry
    if (prewarm.expiresAt <= now) {
      if (prewarm.openaiWs) {
        prewarm.openaiWs.close(1000, "prewarm_expired");
      }
      prewarmSessions.delete(prepId);
      cleaned++;
    }
  }
  if (cleaned > 0) logger.info("Prewarm sessions cleaned", { count: cleaned });
  if (recycled > 0) logger.info("Prewarm sessions recycled (max lifetime)", { count: recycled });
}

setInterval(cleanupExpiredPrewarmSessions, 60_000); // ✅ v7.3.5: check every 60s for max lifetime

