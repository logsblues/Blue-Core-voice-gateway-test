// ============================================================
function injectVoicemailScript(session) {
  if (session._voicemailScriptDelivered) return;

  const script = session.voicemailConfig?.voicemailScript;
  if (!script) return;

  logger.info("[v7.3.4] Voicemail injection requested", {
    callSid: session.callSid,
    hasActiveResponse: !!session._hasActiveResponse,
    scriptLength: script.length
  });

  if (session._hasActiveResponse) {
    // Defer — will execute when response.done fires (handled in setupMessageHandler)
    session._pendingVoicemailInject = true;
    logger.info("[v7.3.4] Response active — deferring injection", { callSid: session.callSid });

    // Safety fallback: 10s max wait
    setTimeout(() => {
      if (session._pendingVoicemailInject && !session._voicemailScriptDelivered) {
        session._pendingVoicemailInject = false;
        session._voicemailScriptDelivered = true;
        logger.warn("[v7.3.4] 10s fallback — forcing voicemail injection", { callSid: session.callSid });
        if (session.openaiWs?.readyState === WebSocket.OPEN) {
          session.openaiWs.send(JSON.stringify({ type: "response.cancel" }));
