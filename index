            toolCallLog: [],
            dynamicTools: dynamicTools || null,  // NEW v7
            playbook: playbook || null,           // NEW v7
            sessionCreated: false,
            sessionReady: false,
            greetingMessageSent: false,
            greetingTriggered: false,
            callEnding: false,
